# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-only, NUNCA expor no client

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── E-mail transacional (Resend) — convites, reset ─────────
RESEND_API_KEY=re_...
RESEND_FROM="Dedetech <nao-responder@dedetech.com.br>"

# ─── Observabilidade ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Integrações (fases futuras) ────────────────────────────
# ASAAS_API_KEY=
# PLUGNOTAS_API_KEY=
# TRIGGER_SECRET_KEY=
# TRACCAR_URL=

# Meta Ads (dashboard /trafego) — token de longa duração (renovar a cada ~60 dias)
META_ADS_TOKEN=
META_AD_ACCOUNT_ID=act_...
META_CAMPAIGN_ID=

# ─── Bot IA da landing (WhatsApp Cloud API oficial) ─────────
WHATSAPP_TENANT_ID=                # tenant que o número atende (MVP: um só)
WHATSAPP_TOKEN=                    # token da Graph API (envio)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=             # handshake do webhook
WHATSAPP_APP_SECRET=              # OBRIGATÓRIO: valida a assinatura X-Hub-Signature-256. Sem ele o webhook não processa
BOT_DESLIGADO=                     # =true desliga o bot sem redeploy (kill-switch)

# ─── Asaas (webhook) ────────────────────────────────────────
# O caminho correto é o webhook_token POR EMPRESA (payment_integrations).
# ASAAS_WEBHOOK_TOKEN=             # token global LEGADO (quita qualquer tenant)
# ASAAS_WEBHOOK_ALLOW_LEGACY=      # =true reativa o token global legado (emergência)
